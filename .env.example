# Copy this file to .env and adjust if needed.
# Local-first SQLite database file, relative to the project root.
DATABASE_URL="file:./dev.db"

# Base URL embedded in QR codes / repair receipts.
# Default works on the same machine. For a live demo where a customer scans the
# QR with their phone, set this to the laptop's LAN address so the phone (on the
# same Wi-Fi) can open it, e.g. APP_URL="http://192.168.1.50:3000".
APP_URL="http://localhost:3000"
